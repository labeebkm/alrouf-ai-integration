# AL ROUF AI Integration – Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── LLM Provider ───────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ── CRM Integration (Task 1) ────────────────────────────────
HUBSPOT_API_KEY=your-hubspot-api-key-here
HUBSPOT_PIPELINE_ID=default
HUBSPOT_STAGE_ID=appointmentscheduled

# ── Notification Channels (Task 1) ─────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_EMAIL_FROM=alerts@yourdomain.com
ALERT_EMAIL_TO=sales@yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# ── Storage / Archiving (Task 1) ────────────────────────────
ATTACHMENT_STORAGE_PATH=./attachments
# Optional: S3-compatible storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ── Quotation Service (Task 2) ──────────────────────────────
QUOTATION_SERVICE_PORT=8000
QUOTATION_SECRET_KEY=change-me-in-production-min-32-chars
PRICE_LIST_PATH=./data/price_list.json

# ── RAG Workflow (Task 3) ───────────────────────────────────
VECTOR_STORE_PATH=./vector_store
DOCS_PATH=./docs/knowledge_base
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RESULTS=4

# ── Global ──────────────────────────────────────────────────
# Set to "true" to run entirely offline with mocks (no API keys needed)
MOCK_MODE=false
LOG_LEVEL=INFO
